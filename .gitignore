# Dependency directories
**/node_modules/
**/venv/
**/.venv/
**/env/
**/ENV/

# Build directories
**/dist/
**/dist-ssr/
**/build/
**/staticfiles/

# Environment files (sensitive credentials)
**/.env
**/.env.*
*.env

# Docker/Compose overrides
docker-compose.override.yml

# Databases
**/*.sqlite3
**/db.sqlite3

# Python cache and byte-code
**/__pycache__/
**/*.pyc
**/*.pyo
**/*.pyd

# Log files
*.log
**/logs/
**/npm-debug.log*
**/yarn-debug.log*
**/yarn-error.log*
**/pnpm-debug.log*

# Editor & System files
**/.vscode/
!**/.vscode/extensions.json
**/.idea/
**/.DS_Store
**/*.suo
**/*.ntvs*
**/*.njsproj
**/*.sln
**/*.sw?
